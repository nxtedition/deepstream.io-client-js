{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noCheck": true,
    "noImplicitAny": true,
    "rewriteRelativeImportExtensions": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "rootDir": "./src",
    "outDir": "./lib",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["./src"],
  "exclude": ["**/*.test-d.*", "**/*.test.*"]
}
